# Mira — Visual Reading Companion
# Copy to .env.local and fill in your keys

# Image generation (OpenAI DALL·E or compatible)
IMAGE_GEN_API_KEY=sk-your-key-here
IMAGE_GEN_BASE_URL=https://api.openai.com/v1
IMAGE_GEN_MODEL=dall-e-3

# LLM text extraction (OpenAI or compatible)
# Defaults to IMAGE_GEN_API_KEY if not set
EXTRACT_API_KEY=
EXTRACT_BASE_URL=
EXTRACT_MODEL=gpt-4o-mini
